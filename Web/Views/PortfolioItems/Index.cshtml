@model Web.ViewModels.DashboardViewModel
@using Microsoft.AspNetCore.Identity
@using Core.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Portfolio Management";
    var currentUser = await UserManager.GetUserAsync(User);

    var sortedItems = Model.PortfolioItems?.OrderByDescending(x => x.CreatedDate).ToList();
}
<div id="flower-container"></div>
<div class="index-container animate__animated animate__fadeIn">

    <div class="hero-management-section mb-5">
        <div class="card shadow border-0 custom-card">
            <div class="card-header custom-header d-flex justify-content-between align-items-center py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="fas fa-user-shield me-2 pulse-icon"></i> Hero Section Control
                </h5>

                <a asp-controller="Contact" asp-action="Index" class="msg-icon-container text-decoration-none" title="View Messages">
                    <i class="fas fa-envelope fa-lg text-white"></i>
                    @if (Model.UnreadMessagesCount > 0)
                    {
                        <span class="msg-badge-count">
                            @Model.UnreadMessagesCount
                        </span>
                    }
                </a>
            </div>

            <div class="card-body p-4 bg-white">
                <div class="row align-items-center">
                    <div class="col-md-auto text-center mb-3 mb-md-0">
                        <div class="profile-preview-wrapper float-animation">
                            @if (Model.OwenerInfo?.Avatar != null)
                            {
                                <img src="~/img/@Model.OwenerInfo.Avatar" class="rounded-circle shadow" style="width: 120px; height: 120px; object-fit: cover; border: 5px solid #2c3e50;" />
                            }
                            else
                            {
                                <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 120px; height: 120px; border: 5px solid #2c3e50; background-color: #f8f9fa;">
                                    <i class="fas fa-user-tie fa-4x" style="color: #2c3e50;"></i>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-md ps-md-4">
                        <h2 class="fw-bold mb-1 tracking-in-expand" style="color: #2c3e50; text-transform: uppercase;">
                            @(currentUser?.FullName ?? Model.OwenerInfo?.FullName ?? "ADMIN USER")
                        </h2>
                        <p class="text-muted mb-3 slide-in-bottom" style="font-size: 1.1rem; border-left: 3px solid #1abc9c; padding-left: 15px;">
                            @(Model.OwenerInfo?.Profile ?? "Profile description not set yet.")
                        </p>

                        <div class="d-flex flex-wrap gap-3 align-items-center">
                            <a href="/Owner/Edit/@Model.OwenerInfo?.Id" class="btn-shine text-decoration-none">
                                <i class="fas fa-edit me-2"></i> Update Hero Info
                            </a>

                            <form action="@Url.Action("Logout", "Account")" method="post" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-logout-animated border-0 bg-transparent p-0">
                                    <span class="btn-logout-inner">
                                        <i class="fas fa-sign-out-alt me-2"></i> Logout
                                    </span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="divider-custom my-5">
        <div class="divider-custom-line"></div>
        <div class="divider-custom-icon rotate-center"><i class="fas fa-star"></i></div>
        <div class="divider-custom-line"></div>
    </div>

    <div class="header-section d-flex flex-wrap justify-content-between align-items-center mb-4 px-2 gap-3">
        <div class="d-flex align-items-center gap-3">
            <h1 class="page-title mb-0" style="color: #2c3e50; font-weight: 800;">Portfolio Items</h1>
            <span class="badge rounded-pill bg-dark shadow-sm py-2 px-3 animate__animated animate__bounceIn" style="font-size: 0.9rem; background: #2c3e50 !important;">
                <i class="fas fa-project-diagram me-1 text-info"></i> @(sortedItems?.Count ?? 0)
            </span>
        </div>

        <a asp-action="Create" class="btn btn-create-animated text-decoration-none">
            <span>Create New Project</span>
            <i class="fas fa-plus"></i>
        </a>
    </div>

    @if (sortedItems != null && sortedItems.Any())
    {
        <div class="table-responsive-custom d-none d-lg-block">
            <table class="table-modern w-100">
                <thead>
                    <tr>
                        <th>PROJECT NAME</th>
                        <th>DESCRIPTION</th>
                        <th class="text-center">CREATED DATE</th>
                        <th class="text-center">STATUS</th>
                        <th class="text-center">PREVIEW</th>
                        <th class="text-center">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in sortedItems)
                    {
                        <tr class="table-row-hover">
                            <td class="fw-bold" style="color: #2c3e50; padding: 15px;">@item.ProjectName</td>
                            <td><div class="text-truncate" style="max-width: 200px; color: #7f8c8d;">@item.Description</div></td>
                            <td class="text-center">
                                <span class="text-muted small">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    @item.CreatedDate.ToString("dd MMM yyyy")
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <div class="status-pill online"><span class="ping"></span> Online</div>
                                }
                                else
                                {
                                    <div class="status-pill offline">Hidden</div>
                                }
                            </td>
                            <td class="text-center">
                                <div class="img-frame">
                                    <img src="~/img/portfolio/@item.ImageUrl" alt="Project" />
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="action-btns-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon edit" title="Edit"><i class="fas fa-pen"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon view" title="View"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon delete" title="Delete"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mobile-portfolio-grid d-lg-none">
            @foreach (var item in sortedItems)
            {
                <div class="mobile-card shadow-sm mb-4">
                    <div class="mobile-card-img">
                        <img src="~/img/portfolio/@item.ImageUrl" />
                        <div class="mobile-status">
                            @if (item.IsActive)
                            {<span class="badge bg-success">Online</span> }
                            else
                            { <span class="badge bg-secondary">Hidden</span>}
                        </div>
                    </div>
                    <div class="mobile-card-body p-3 text-center">
                        <h5 class="fw-bold mb-1">@item.ProjectName</h5>

                        <div class="text-muted small mb-2">
                            <i class="far fa-calendar-alt me-1"></i> @item.CreatedDate.ToString("dd/MM/yyyy")
                        </div>

                        <p class="text-muted small">@item.Description</p>
                        <hr />
                        <div class="mobile-card-actions d-flex justify-content-around">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon edit"><i class="fas fa-pen"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon view"><i class="fas fa-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon delete"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state-container text-center py-5 animate__animated animate__zoomIn">
            <div class="empty-icon-wrapper mb-4">
                <i class="fas fa-folder-open fa-5x text-muted opacity-50"></i>
                <div class="no-data-animation"></div>
            </div>
            <h3 class="fw-bold text-secondary">No Projects Found</h3>
            <p class="text-muted">Your portfolio is currently empty. Start showcasing your work by adding your first project!</p>
            <a asp-action="Create" class="btn btn-outline-primary btn-lg px-5 mt-3 rounded-pill">
                <i class="fas fa-plus-circle me-2"></i>Add First Project
            </a>
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center mt-5">
            <ul class="pagination pagination-custom shadow-sm">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage - 1)">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.CurrentPage + 1)">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    @@import url('https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css');


    .msg-icon-container {
        position: relative;
        display: inline-block;
        padding: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .msg-icon-container:hover {
            background: #1abc9c;
            transform: translateY(-3px);
        }

    .msg-badge-count {
        position: absolute;
        top: -5px;
        right: -5px;
        background: #e74c3c;
        color: white;
        border-radius: 50%;
        padding: 2px 6px;
        font-size: 10px;
        font-weight: bold;
        border: 2px solid #2c3e50;
        animation: pulse-red 2s infinite;
    }


    .pagination-custom .page-link {
        border: none;
        color: #2c3e50;
        margin: 0 5px;
        border-radius: 8px !important;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .pagination-custom .page-item.active .page-link {
        background-color: #1abc9c;
        color: white;
        box-shadow: 0 4px 10px rgba(26, 188, 156, 0.3);
    }

    .pagination-custom .page-link:hover:not(.active) {
        background-color: #f8f9fa;
        color: #1abc9c;
        transform: translateY(-2px);
    }

    .empty-state-container {
        background: #fdfdfd;
        border: 2px dashed #dee2e6;
        border-radius: 20px;
        margin: 20px 0;
    }

    .index-container {
        margin-top: 140px;
        margin-bottom: 80px;
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        padding: 0 20px;
    }

    .custom-card {
        border-radius: 20px;
        transition: all 0.4s ease;
        background: #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .custom-header {
        background-color: #2c3e50;
        color: #fff;
        border: none;
        border-radius: 20px 20px 0 0 !important;
    }

    .btn-shine {
        position: relative;
        overflow: hidden;
        background: #2c3e50;
        color: white;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 600;
        display: inline-block;
        transition: 0.3s;
    }

        .btn-shine:hover {
            background: #1abc9c;
            color: #fff;
            box-shadow: 0 5px 15px rgba(26, 188, 156, 0.4);
            transform: translateY(-2px);
        }

    .btn-logout-animated .btn-logout-inner {
        background: #fff;
        color: #e74c3c;
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 600;
        border: 2px solid #e74c3c;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .btn-logout-animated:hover .btn-logout-inner {
        background: #e74c3c;
        color: #fff;
        box-shadow: 0 5px 15px rgba(231, 76, 60, 0.3);
    }

    .btn-create-animated {
        background: #1abc9c;
        color: white;
        padding: 12px 25px;
        border-radius: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: 0.3s;
    }

        .btn-create-animated:hover {
            background: #16a085;
            color: white;
            transform: scale(1.05);
        }

    .table-modern {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 15px;
    }

    .table-row-hover {
        background: #fff;
        transition: 0.3s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

    .status-pill {
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        margin: auto;
    }

    .online {
        background: #e6f7f4;
        color: #1abc9c;
    }

    .offline {
        background: #fdeaea;
        color: #e74c3c;
    }

    .ping {
        width: 8px;
        height: 8px;
        background: #1abc9c;
        border-radius: 50%;
        position: relative;
    }

        .ping::after {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            background: inherit;
            border-radius: 50%;
            animation: ping-ani 1.2s infinite;
        }

    @@keyframes ping-ani {
        75%, 100% {
            transform: scale(2.5);
            opacity: 0;
        }
    }

    @@keyframes pulse-red {
        0% {
            box-shadow: 0 0 0 0 rgba(231, 76, 60, 0.7);
        }

        70% {
            box-shadow: 0 0 0 6px rgba(231, 76, 60, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(231, 76, 60, 0);
        }
    }

    .img-frame {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        overflow: hidden;
        margin: auto;
    }

        .img-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .float-animation {
        animation: floating 3s ease-in-out infinite;
    }

    @@keyframes floating {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    .divider-custom {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .divider-custom-line {
        height: 4px;
        background: #2c3e50;
        border-radius: 10px;
        width: 80px;
    }

    .divider-custom-icon {
        font-size: 1.5rem;
        color: #2c3e50;
        margin: 0 15px;
    }

    .action-btns-group {
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .btn-icon {
        font-size: 1.2rem;
        color: #7f8c8d;
        transition: 0.3s;
        text-decoration: none;
    }

        .btn-icon:hover {
            transform: scale(1.2);
        }

        .btn-icon.edit:hover {
            color: #3498db;
        }

        .btn-icon.view:hover {
            color: #2ecc71;
        }

        .btn-icon.delete:hover {
            color: #e74c3c;
        }

    .mobile-card {
        background: #fff;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .mobile-card-img {
        height: 200px;
        position: relative;
    }

        .mobile-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .mobile-status {
        position: absolute;
        top: 10px;
        right: 10px;
    }

#flower-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;   
    z-index: 9999;
    overflow: hidden;
}

    .flower {
        position: absolute;
        top: -50px; 
        font-size: 1.5rem;
        user-select: none;
        animation: flower-fall linear forwards;
    }

    @@keyframes flower-fall {
        0% {
            transform: translateY(0) rotate(0deg);
            opacity: 0;
        }

        10% {
            opacity: 1;
        }

        100% {
            transform: translateY(110vh) translateX(var(--dx)) rotate(var(--dr));
            opacity: 0.3;
        }
    }


    @@media (max-width: 991px) {
        .btn-shine, .btn-logout-animated, .btn-create-animated {
            width: 100%;
            text-align: center;
            justify-content: center;
            margin-top: 10px;
        }
    }
</style>
<script>
    function createFlowerRain() {
        const container = document.getElementById('flower-container');
        if (!container) return;

        const flowers = ['🌸', '🌼', '🌺', '🌻', '🌷', '🌹', '🍃'];

        function spawnFlower() {
           
            for (let i = 0; i < 3; i++) {
                const flower = document.createElement('div');
                flower.className = 'flower';
                flower.innerHTML = flowers[Math.floor(Math.random() * flowers.length)];

                const startX = Math.random() * window.innerWidth;
                const duration = 3 + Math.random() * 4;
                const size = 0.8 + Math.random() * 1.2;

                flower.style.left = startX + 'px';
                flower.style.fontSize = size + 'rem';
                flower.style.animationDuration = duration + 's';

                flower.style.setProperty('--dr', (Math.random() * 720) + 'deg');
                flower.style.setProperty('--dx', (Math.random() * 300 - 150) + 'px');

                container.appendChild(flower);
                setTimeout(() => flower.remove(), duration * 1000);
            }
        }

       
        const rainInterval = setInterval(spawnFlower, 50);

        setTimeout(() => {
            clearInterval(rainInterval);
            console.log("Flower rain stopped."); 
        }, 10000);
    }

    window.addEventListener('DOMContentLoaded', createFlowerRain);
</script>
