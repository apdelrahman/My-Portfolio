@using Core.Entities
@model IEnumerable<Contact>

@{
    ViewData["Title"] = "User Messages";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalMessages = ViewBag.TotalMessagesCount ?? 0;

    var unreadCount = Model.Count(m => !m.IsRead);
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Cairo:wght@400;700&display=swap" rel="stylesheet">

@* --- Image Full View Modal --- *@
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 text-center position-relative">
                <img id="fullViewImage" src="" class="img-fluid rounded shadow-lg" style="max-height: 90vh; cursor: pointer;" data-bs-dismiss="modal">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal"></button>
            </div>
        </div>
    </div>
</div>

@* --- Drawer Overlay --- *@
<div id="drawerOverlay" class="drawer-overlay" onclick="closeDrawer()"></div>

@* --- Side Drawer (Floating Design) --- *@
<div id="msgDrawer" class="side-drawer shadow-lg">
    <div class="drawer-header d-flex justify-content-between align-items-center p-4 bg-dark text-white flex-shrink-0">
        <h5 class="fw-bold mb-0"><i class="fas fa-envelope-open-text me-2"></i> Message Details</h5>
        <button class="btn btn-sm btn-outline-light rounded-circle" onclick="closeDrawer()">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <div class="drawer-body p-4 flex-grow-1">
        <div class="mb-4">
            <label class="text-muted small text-uppercase fw-bold">From</label>
            <div class="d-flex align-items-center mt-1">
                <div id="d_avatar" class="avatar-circle me-3"></div>
                <div>
                    <h6 id="d_name" class="fw-bold mb-0 text-dark"></h6>
                    <span id="d_email" class="text-primary small"></span>
                </div>
            </div>
            <small id="d_date" class="text-muted d-block mt-2 italic border-start ps-2"></small>
        </div>

        <hr class="opacity-10">

        <div class="mb-4">
            <label class="text-muted small text-uppercase fw-bold mb-2 d-block">Message Content</label>
            <div class="message-text-container bg-light p-3 rounded-3 border">
                <p id="d_body" style="white-space: pre-wrap; color:#333; line-height:1.6; font-size: 0.95rem;"></p>
            </div>
        </div>

        <div class="mb-4">
            <label class="text-muted small text-uppercase fw-bold mb-2 d-block">
                <i class="fas fa-paperclip me-1"></i> Attachment
            </label>
            <div id="attachment_container" class="attachment-preview-box border rounded-3 p-3 bg-white shadow-sm text-center" style="display:none !important;">
                <img id="d_image" src="" class="img-fluid rounded mb-3 shadow-sm preview-trigger" style="max-height: 250px; cursor: zoom-in;" />
                <div class="d-flex justify-content-between align-items-center mt-2 border-top pt-2">
                    <span class="small fw-bold text-dark"><i class="far fa-image me-1"></i> Attachment File</span>
                    <a id="d_download" href="#" download class="btn btn-sm btn-primary px-3 rounded-pill">
                        <i class="fas fa-download me-1"></i> Download
                    </a>
                </div>
            </div>
            <div id="d_no_files" class="py-4 text-center border rounded-3 bg-light text-muted small border-dashed">
                <i class="fas fa-file-slash d-block mb-2 fa-2x opacity-25"></i> No attachments
            </div>
        </div>
    </div>

    <div class="drawer-footer p-4 border-top bg-light flex-shrink-0">
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary w-50 py-2 fw-bold rounded-pill" onclick="closeDrawer()">Close</button>
            <a id="d_reply" href="#" class="btn btn-dark w-50 py-2 fw-bold rounded-pill shadow-sm">
                <i class="fas fa-reply me-2"></i> Reply
            </a>
        </div>
    </div>
</div>

<div class="index-container animate__animated animate__fadeIn">

    @* --- Header Section --- *@
    <div class="header-section d-flex flex-wrap justify-content-between align-items-end mb-5 px-2 gap-3">
        <div>
            <div class="d-flex align-items-center gap-3 mb-1">
                <h1 class="page-title mb-0 fw-bold">Inbox</h1>
                <span class="badge rounded-pill bg-dark shadow-sm py-2 px-3" style="font-size: 0.85rem; background: #2c3e50 !important;">
                    <i class="fas fa-envelope me-1 text-info"></i> @totalMessages
                </span>

                @if (unreadCount > 0)
                {
                    <span class="badge rounded-pill bg-danger animate__animated animate__pulse animate__infinite unread-badge">@unreadCount New in Page</span>
                }
            </div>
            <p class="text-muted mb-0">Manage and respond to your inquiries</p>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="form-check me-2">
                <input class="form-check-input select-all-btn" type="checkbox" id="selectAll">
                <label class="form-check-label small fw-bold text-muted" for="selectAll">Select All</label>
            </div>
            <button type="button" id="bulkDeleteBtn" class="btn btn-danger rounded-pill px-4 shadow-sm" style="display:none;" onclick="handleBulkDelete()">
                <i class="fas fa-trash-alt me-2"></i> Delete <span></span>
            </button>
            <a href="/PortfolioItems/Index" class="btn-shine">
                <i class="fas fa-arrow-left me-2"></i> Dashboard
            </a>
        </div>
    </div>

    @* --- Main Content & Card Grid --- *@
    @if (!Model.Any())
    {
        <div class="empty-state text-center py-5 animate__animated animate__fadeIn">
            <div class="empty-icon-circle mb-4">
                <i class="fas fa-inbox fa-3x text-muted opacity-50"></i>
            </div>
            <h3 class="fw-bold text-dark">Your inbox is clear!</h3>
            <p class="text-muted">When you receive new messages, they will appear here.</p>
        </div>
    }
    else
    {
        <form id="bulkDeleteForm" asp-action="DeleteMultiple" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-4 justify-content-center">
                @foreach (var message in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4" id="card-@message.Id">
                        <div class="msg-card @(message.IsRead ? "" : "unread-card") bg-white-glass position-relative">
                            <div class="card-selection">
                                <input class="form-check-input msg-checkbox" type="checkbox" name="ids" value="@message.Id">
                            </div>

                            <div class="card-content p-4" onclick="viewMessage('@message.Id')">
                                <div class="d-flex align-items-center mb-3">
                                    @{ var initial = !string.IsNullOrEmpty(message.FullName) ? message.FullName.Substring(0, 1).ToUpper() : "?"; }
                                    <div class="avatar-circle-lg me-3">@initial</div>
                                    <div class="overflow-hidden">
                                        <h6 class="fw-bold mb-0 text-dark text-truncate">@message.FullName</h6>
                                        <small class="text-muted">@message.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    </div>
                                </div>

                                <div class="msg-preview mb-3">
                                    <p class="text-muted small line-clamp-2 mb-0">@message.Message</p>
                                </div>

                                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                                    <span class="small text-primary fw-bold text-truncate me-2">@message.Email</span>
                                    <div class="card-actions">
                                        <i id="icon-@message.Id" class="fas @(message.IsRead ? "fa-envelope-open text-muted" : "fa-envelope text-primary") me-2"></i>
                                        @if (!string.IsNullOrEmpty(message.AttachmentUrl))
                                        {<i class="fas fa-paperclip text-muted small"></i>}
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer-btns">
                                <button type="button" class="btn-card-del" onclick="submitSingleDelete('@message.Id'); event.stopPropagation();">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </form>

        @* --- Pagination Section --- *@
        @if (totalPages > 1)
        {
            <nav class="mt-5 d-flex justify-content-center">
                <ul class="pagination pagination-custom shadow-sm rounded-pill p-1 bg-white">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link rounded-circle border-0 mx-1" href="?page=@(currentPage - 1)">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link rounded-circle border-0 mx-1" href="?page=@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link rounded-circle border-0 mx-1" href="?page=@(currentPage + 1)">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<form id="singleDeleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="singleDeleteId" />
</form>

<style>
    :root {
        --primary-glow: rgba(0, 123, 255, 0.15);
        --glass-bg: rgba(255, 255, 255, 0.85);
        --accent: #2c3e50;
    }

    body {
        font-family: 'Inter', 'Cairo', sans-serif;
        background-color: #f4f7f9;
    }

    .index-container {
        margin: 110px auto 80px;
        max-width: 1300px;
        padding: 0 20px;
    }

    .bg-white-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
    }

    .side-drawer {
        position: fixed;
        top: 20px;
        right: -470px;
        width: 450px;
        max-width: calc(100% - 40px);
        height: calc(100vh - 40px);
        background: #fff;
        z-index: 2000;
        transition: right 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        flex-direction: column;
        border-radius: 25px;
        margin-right: 20px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

        .side-drawer.open {
            right: 0;
        }

    .drawer-body {
        overflow-y: auto;
    }

    .msg-card {
        border-radius: 20px;
        transition: 0.3s;
        cursor: pointer;
        height: 100%;
        border: 1px solid transparent;
    }

        .msg-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            border-color: #007bff;
        }

    .unread-card {
        border-left: 5px solid #007bff !important;
        background-color: #f0f7ff;
    }

    .avatar-circle-lg {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #2c3e50, #4ca1af);
        color: white;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
    }

    .avatar-circle {
        width: 45px;
        height: 45px;
        background: #2c3e50;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .card-footer-btns {
        position: absolute;
        bottom: 15px;
        right: 15px;
        opacity: 0;
        transition: 0.3s;
    }

    .msg-card:hover .card-footer-btns {
        opacity: 1;
    }

    .btn-card-del {
        background: #fff1f1;
        color: #e53e3e;
        border: none;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

        .btn-card-del:hover {
            background: #e53e3e;
            color: #fff;
        }

    .btn-shine {
        background: #2c3e50;
        color: white;
        padding: 12px 25px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(44, 62, 80, 0.3);
        transition: 0.3s;
    }

        .btn-shine:hover {
            background: #1abc9c;
            color: #fff;
            transform: translateY(-2px);
        }

    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.3);
        backdrop-filter: blur(4px);
        display: none;
        z-index: 1999;
    }

    /* Pagination Styling */
    .pagination-custom .page-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-weight: 600;
        transition: 0.3s;
    }

    .pagination-custom .page-item.active .page-link {
        background-color: var(--accent) !important;
        color: white !important;
    }

    .pagination-custom .page-item.disabled .page-link {
        color: #ccc;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

@section Scripts {
    <script>
        function submitSingleDelete(id) {
            if (confirm('Move this message to trash?')) {
                $('#singleDeleteId').val(id);
                $('#singleDeleteForm').submit();
            }
        }

        $(document).on('click', '.preview-trigger', function () {
            $('#fullViewImage').attr('src', $(this).attr('src'));
            new bootstrap.Modal(document.getElementById('imageModal')).show();
        });

        $('#selectAll').click(function () {
            $('.msg-checkbox').prop('checked', this.checked);
            toggleBulkBtn();
        });

        $(document).on('change', '.msg-checkbox', toggleBulkBtn);

        function toggleBulkBtn() {
            const count = $('.msg-checkbox:checked').length;
            if (count > 0) {
                $('#bulkDeleteBtn').fadeIn().find('span').text(`(${count})`);
            } else {
                $('#bulkDeleteBtn').fadeOut();
            }
        }

        function handleBulkDelete() {
            if (confirm(`Delete ${$('.msg-checkbox:checked').length} messages?`)) {
                $('#bulkDeleteForm').submit();
            }
        }

        function viewMessage(id) {
            $('.drawer-body').scrollTop(0);
            $.get('/Contact/GetMessageDetails/' + id, function (data) {
                $('#d_name').text(data.fullName);
                $('#d_email').text(data.email);
                $('#d_body').text(data.messageContent);
                $('#d_date').text(data.date);
                $('#d_avatar').text(data.fullName ? data.fullName.substring(0, 1).toUpperCase() : "?");

                if (data.imageUrl && data.imageUrl !== "" && data.imageUrl !== "/uploads/") {
                    $('#d_image').attr('src', data.imageUrl).show();
                    // --- الإصلاح هنا: نقوم بتحديث رابط التحميل بمسار الصورة ---
                    $('#d_download').attr('href', data.imageUrl);

                    $('#attachment_container').attr('style', 'display: block !important');
                    $('#d_no_files').hide();
                } else {
                    $('#attachment_container').hide();
                    $('#d_no_files').show();
                    $('#d_download').attr('href', '#');
                }

                $('#d_reply').attr('href', 'mailto:' + data.email);
                $(`#card-${id}`).find('.msg-card').removeClass('unread-card');
                $(`#icon-${id}`).removeClass('fa-envelope text-primary').addClass('fa-envelope-open text-muted');

                $('#msgDrawer').addClass('open');
                $('#drawerOverlay').fadeIn();
                $('body').css('overflow', 'hidden');
            });
        }

        function closeDrawer() {
            $('#msgDrawer').removeClass('open');
            $('#drawerOverlay').fadeOut();
            $('body').css('overflow', 'auto');
        }
    </script>
}